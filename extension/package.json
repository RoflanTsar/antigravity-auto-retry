{
  "name": "antigravity-auto-retry",
  "displayName": "Antigravity Auto Retry",
  "description": "Automatically clicks the Retry button when Antigravity shows the high-traffic error.",
  "version": "0.2.0",
  "publisher": "RoflanTsar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RoflanTsar/antigravity-auto-retry.git"
  },
  "engines": {
    "vscode": "^1.68.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Antigravity Auto Retry",
      "properties": {
        "antigravityAutoRetry.circuitBreaker.mode": {
          "type": "string",
          "enum": [
            "cooldown",
            "stop"
          ],
          "default": "cooldown",
          "markdownDescription": "What to do after the retry circuit breaker trips. `cooldown` temporarily pauses and auto-resumes. `stop` keeps the old behavior and requires `antigravityAutoRetry.reset()` or a reload."
        },
        "antigravityAutoRetry.circuitBreaker.cooldownSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "maximum": 3600,
          "markdownDescription": "How long to pause before auto-resuming when `antigravityAutoRetry.circuitBreaker.mode` is `cooldown`. Changes apply after the patch is refreshed/reapplied and the window is reloaded."
        }
      }
    },
    "commands": [
      {
        "command": "antigravityAutoRetry.install",
        "title": "Antigravity Auto Retry: Install"
      },
      {
        "command": "antigravityAutoRetry.uninstall",
        "title": "Antigravity Auto Retry: Uninstall"
      },
      {
        "command": "antigravityAutoRetry.reapply",
        "title": "Antigravity Auto Retry: Reapply (after update)"
      },
      {
        "command": "antigravityAutoRetry.refreshScript",
        "title": "Antigravity Auto Retry: Refresh Retry Script"
      },
      {
        "command": "antigravityAutoRetry.status",
        "title": "Antigravity Auto Retry: Show Status"
      },
      {
        "command": "antigravityAutoRetry.openScript",
        "title": "Antigravity Auto Retry: Open Retry Script"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "package": "npx --yes @vscode/vsce package --allow-missing-repository --out ../antigravity-auto-retry.vsix"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.68.0",
    "typescript": "^5.4.0"
  }
}
